# Inbox scan (Dashboard → “Scan inbox now”) uses Gmail + OpenAI to classify threads and sentiment.
# Same credentials as Sentinel. Without OpenAI, rule-based fallback is used (less accurate).

# Google OAuth2 (Gmail + Calendar)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Use OAuth 2.0 Client ID (Desktop or Web). Scopes: gmail (readonly, modify, compose), calendar (readonly).
# Run the OAuth flow once to get a refresh token and set it here.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# OpenAI – PersonaEngine, JobHunter sequence, VoiceLab, Sentinel
OPENAI_API_KEY=

# Gemini – preferred for JobHunter research (Google Search / open internet). Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: Gmail push (Pub/Sub topic). If set, POST /api/sentinel/gmail/watch to start watching.
# GMAIL_WATCH_TOPIC=projects/YOUR_PROJECT/topics/gmail

# Optional: base URL for scripts/run-sentinel.js when calling the API
# SENTINEL_URL=http://localhost:3000

# Optional: Apollo.io – paid; verified contacts for JobHunter (used only if set)
# APOLLO_API_KEY=

# Supabase (waitlist landing page at /waitlist)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Root `/` → waitlist: on Vercel this is the default. Set 0 to serve the full app at `/`.
# Local dev: set LANDING_AT_ROOT=1 to test the redirect, or open /waitlist directly.
# LANDING_AT_ROOT=0
#
# While waitlist is live at `/`, open the app at `/` (Command Center) or `/dashboard` (same UI),
# plus `/profile`, `/match-lab`, `/interview-iq`, etc.

# Demo data: POST /api/demo/seed and Dashboard “Load sample…” are allowed in development by default.
# On Vercel, set to 1 to enable (e.g. for screenshots). Omit or 0 in production.
# ALLOW_DEMO_SEED=1
